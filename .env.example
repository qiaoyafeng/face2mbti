# Face2MBTI 配置
# 复制此文件为 .env 并填写实际值

# 服务端口（Docker 宿主机映射端口 & 容器内监听端口）
APP_PORT=8000

# OpenAI 兼容 API 配置
OPENAI_API_KEY=your-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
MODEL_NAME=gpt-4o

# 大模型思考模式（true=开启，false=关闭，默认关闭）
ENABLE_THINKING=false

# 视频分析配置
VIDEO_MAX_SIZE_MB=50
VIDEO_MAX_DURATION_SEC=30
FRAME_INTERVAL_SEC=5.0

# 文件存储目录
UPLOAD_DIR=./uploads
LOG_DIR=./logs

# 前端轮询间隔（秒）
POLL_INTERVAL_SEC=5
